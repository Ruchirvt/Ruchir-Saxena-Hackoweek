<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShopPro - Modern Store</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">

<!-- NAVBAR -->
<nav class="bg-white shadow-md fixed w-full z-50">
  <div class="max-w-7xl mx-auto px-6 py-4 flex justify-between items-center">
    <h1 class="text-2xl font-bold text-indigo-600">ShopPro</h1>
    <div class="flex items-center gap-6">
      <button onclick="toggleCart()" class="relative">
        🛒
        <span id="cart-count" class="absolute -top-2 -right-2 bg-red-500 text-white text-xs px-2 py-1 rounded-full">0</span>
      </button>
    </div>
  </div>
</nav>

<!-- HERO -->
<section class="pt-28 pb-16 bg-indigo-600 text-white text-center">
  <h2 class="text-4xl md:text-5xl font-bold mb-4">Upgrade Your Lifestyle</h2>
  <p class="text-lg mb-6">Premium products at unbeatable prices</p>
  <button class="bg-white text-indigo-600 px-6 py-3 rounded-lg font-semibold hover:bg-gray-200">
    Shop Now
  </button>
</section>

<!-- PRODUCTS -->
<section class="max-w-7xl mx-auto px-6 py-16">
  <h3 class="text-3xl font-bold mb-10 text-center">Featured Products</h3>
  <div id="product-grid" class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-8">
  </div>
</section>

<!-- CART SIDEBAR -->
<div id="cart-sidebar" class="fixed right-0 top-0 w-96 h-full bg-white shadow-2xl transform translate-x-full transition duration-300 z-50">
  <div class="p-6 flex justify-between items-center border-b">
    <h2 class="text-xl font-bold">Your Cart</h2>
    <button onclick="toggleCart()">✖</button>
  </div>

  <div id="cart-items" class="p-6 space-y-4 overflow-y-auto h-[60%]"></div>

  <div class="p-6 border-t">
    <div class="flex justify-between font-semibold text-lg mb-4">
      <span>Total:</span>
      <span>$<span id="cart-total">0</span></span>
    </div>
    <button class="w-full bg-indigo-600 text-white py-3 rounded-lg hover:bg-indigo-700">
      Checkout
    </button>
  </div>
</div>

<script>
const products = [
  { id: 1, name: "Wireless Headphones", price: 120, image: "data:image/jpeg;base64," },
  { id: 2, name: "Smart Watch", price: 180, image: "data:image/jpeg;base64," },
  { id: 3, name: "Gaming Mouse", price: 60, image: "data:image/jpeg;base64," },
  { id: 4, name: "Bluetooth Speaker", price: 95, image: "data:image/jpeg;base64," },
  { id: 5, name: "Laptop Backpack", price: 75, image: "data:image/jpeg;base64," },
  { id: 6, name: "Mechanical Keyboard", price: 140, image: "data:image/jpeg;base64," },
  { id: 7, name: "Fitness Tracker", price: 110, image: "data:image/jpeg;base64," },
  { id: 8, name: "Power bank", price: 50, image: "data:image/jpeg;base64," }
];

let cart = [];

const productGrid = document.getElementById("product-grid");

products.forEach(product => {
  productGrid.innerHTML += `
    <div class="bg-white rounded-xl shadow hover:shadow-lg transition p-4">
      <img src="${product.image}" class="rounded-lg mb-4 w-full h-48 object-cover">
      <h4 class="font-semibold text-lg mb-2">${product.name}</h4>
      <p class="text-indigo-600 font-bold text-xl mb-4">$${product.price}</p>
      <button onclick="addToCart(${product.id})"
        class="w-full bg-indigo-600 text-white py-2 rounded-lg hover:bg-indigo-700">
        Add to Cart
      </button>
    </div>
  `;
});

function addToCart(id) {
  const product = products.find(p => p.id === id);
  const item = cart.find(p => p.id === id);

  if (item) {
    item.quantity += 1;
  } else {
    cart.push({ ...product, quantity: 1 });
  }

  updateCart();
}

function updateCart() {
  const cartItems = document.getElementById("cart-items");
  const cartCount = document.getElementById("cart-count");
  const cartTotal = document.getElementById("cart-total");

  cartItems.innerHTML = "";
  let total = 0;
  let count = 0;

  cart.forEach(item => {
    total += item.price * item.quantity;
    count += item.quantity;

    cartItems.innerHTML += `
      <div class="flex justify-between items-center border-b pb-2">
        <div>
          <p class="font-semibold">${item.name}</p>
          <p class="text-sm text-gray-500">$${item.price} x ${item.quantity}</p>
        </div>
        <button onclick="removeFromCart(${item.id})" class="text-red-500">✖</button>
      </div>
    `;
  });

  cartTotal.innerText = total;
  cartCount.innerText = count;
}

function removeFromCart(id) {
  cart = cart.filter(item => item.id !== id);
  updateCart();
}

function toggleCart() {
  document.getElementById("cart-sidebar").classList.toggle("translate-x-full");
}
</script>

</body>
</html>
